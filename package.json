{
  "name": "inventra",
  "version": "1.0.0",
  "description": "Sistema de gestión de inventarios - Inventra",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --forceExit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": ["**/__tests__/**/*.test.js"],
    "collectCoverageFrom": [
      "src/controllers/authController.js",
      "src/controllers/productController.js",
      "src/controllers/movementController.js",
      "src/middleware/asyncHandler.js",
      "src/middleware/authMiddleware.js",
      "src/middleware/errorMiddleware.js",
      "src/utils/generateToken.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 85,
        "functions": 85,
        "branches": 75,
        "statements": 85
      }
    }
  }
}
